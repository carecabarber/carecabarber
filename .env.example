# ══════════════════════════════════════════════════════════════
#  Variáveis de ambiente — copiar para .env (local) ou wsgi.py (PythonAnywhere)
#  NUNCA commitar valores reais neste ficheiro
# ══════════════════════════════════════════════════════════════

# ── Segurança ─────────────────────────────────────────────────
# Chave secreta para sessões Flask (mínimo 32 chars aleatórios)
# Gerar: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=mudar-para-valor-aleatorio-32-chars

# ── Web Push (VAPID) ──────────────────────────────────────────
# Chave privada EC P-256 em base64url (sem padding)
# Gerar: python3 -c "from cryptography.hazmat.primitives.asymmetric import ec; from cryptography.hazmat.primitives import serialization; k=ec.generate_private_key(ec.SECP256R1()); print(k.private_bytes(serialization.Encoding.Raw,serialization.PrivateFormat.Raw,serialization.NoEncryption()).hex())"
# Ou usar: python3 scripts/gerar_vapid.py (se existir)
VAPID_PRIVATE_KEY=base64url-da-chave-privada-EC-P256

# Chave pública correspondente (enviada ao browser para subscrição)
# Derivada automaticamente da chave privada — não alterar sem regenerar o par
VAPID_PUBLIC_KEY=BLj4hePnB09gzgmImA3M02SvlW9H9iyk35NuB85ykeodf1so1YDZuTGdG5P7r_5mCDwrS3GBrYAdDAJfyVi0Law

# ── Sentry (monitorização de erros — opcional) ───────────────
# Sem este valor o Sentry fica desactivado.
# Obter em: https://sentry.io → Settings → Projects → Client Keys (DSN)
SENTRY_DSN=

# ── PythonAnywhere (deploy) ───────────────────────────────────
# Usado por: scripts/pull_db.py, scripts/deploy.py, GitHub Actions
PA_USER=NomeDoUtilizador
PA_TOKEN=token-api-pythonanywhere
PA_DOMAIN=nomedoutilizador.pythonanywhere.com

# ══════════════════════════════════════════════════════════════
#  Como usar localmente:
#    pip install python-dotenv
#    Adicionar ao app.py: from dotenv import load_dotenv; load_dotenv()
#
#  No PythonAnywhere (wsgi.py):
#    os.environ.setdefault("SECRET_KEY", "...")
#    os.environ.setdefault("VAPID_PRIVATE_KEY", "...")
#
#  No GitHub Actions:
#    Settings → Secrets → Actions → New repository secret
#    Criar: PA_USER, PA_TOKEN, PA_DOMAIN
# ══════════════════════════════════════════════════════════════

# ══════════════════════════════════════════════════════════════
#  Railway (migração futura) — copiar para o painel Variables
#  Todas OPCIONAIS: sem elas, o comportamento em PythonAnywhere não muda.
# ══════════════════════════════════════════════════════════════

# Base de dados em volume persistente (filesystem do Railway é efémero).
# Montar um Volume em /data e apontar aqui.
DB_PATH=/data/barbearia.db

# Pasta dos logos, também no volume persistente (senão perdem-se a cada deploy).
LOGOS_DIR=/data/logos

# Um URL por estabelecimento via subdomínio wildcard: <slug>.carecabarber.com.
# Requer DNS wildcard (*.carecabarber.com) a apontar para o Railway.
# Deixar vazio = funcionalidade inerte (sem subdomínios por estabelecimento).
TENANT_BASE_DOMAIN=carecabarber.com

# Origem legítima usada pelo beacon anti-clone. Actualizar para o domínio final.
CANONICAL_URL=https://carecabarber.com

# Aba de separação entre aplicações (app switcher). URL da app Invoice.
# Quando definido, o ROOT (e só o root) vê uma aba no topo para saltar para a
# Invoice. Vazio = sem aba (dormente). Só um link — não mistura as apps.
# IMPORTANTE: usar o URL REAL do serviço Railway da Invoice (ex.: o domínio
# *-production-xxxx.up.railway.app), NUNCA "invoice.<TENANT_BASE_DOMAIN>" —
# esse é o subdomínio reservado que ESTA app intercepta; apontar para ele
# aqui criaria um loop (há uma salvaguarda anti-loop no código, mas o efeito
# seria a aba ficar dormente, não o link funcionar).
INVOICE_URL=https://invoice-production-xxxx.up.railway.app

# NOTA: o Railway injecta PORT automaticamente — NÃO definir aqui.
# O startCommand (railway.json) já faz: waitress-serve --port=$PORT
# NOTA: manter a MESMA VAPID_PRIVATE_KEY da produção actual para não invalidar
# as subscrições de notificações já existentes.
# ══════════════════════════════════════════════════════════════
