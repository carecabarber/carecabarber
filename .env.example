# ══════════════════════════════════════════════════════════════
#  Variáveis de ambiente — copiar para .env (local) ou wsgi.py (PythonAnywhere)
#  NUNCA commitar valores reais neste ficheiro
# ══════════════════════════════════════════════════════════════

# ── Segurança ─────────────────────────────────────────────────
# Chave secreta para sessões Flask (mínimo 32 chars aleatórios)
# Gerar: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=mudar-para-valor-aleatorio-32-chars

# ── Web Push (VAPID) ──────────────────────────────────────────
# Chave privada EC P-256 em base64url (sem padding)
# Gerar: python3 -c "from cryptography.hazmat.primitives.asymmetric import ec; from cryptography.hazmat.primitives import serialization; k=ec.generate_private_key(ec.SECP256R1()); print(k.private_bytes(serialization.Encoding.Raw,serialization.PrivateFormat.Raw,serialization.NoEncryption()).hex())"
# Ou usar: python3 scripts/gerar_vapid.py (se existir)
VAPID_PRIVATE_KEY=base64url-da-chave-privada-EC-P256

# Chave pública correspondente (enviada ao browser para subscrição)
# Derivada automaticamente da chave privada — não alterar sem regenerar o par
VAPID_PUBLIC_KEY=BLj4hePnB09gzgmImA3M02SvlW9H9iyk35NuB85ykeodf1so1YDZuTGdG5P7r_5mCDwrS3GBrYAdDAJfyVi0Law

# ── Sentry (monitorização de erros — opcional) ───────────────
# Sem este valor o Sentry fica desactivado.
# Obter em: https://sentry.io → Settings → Projects → Client Keys (DSN)
SENTRY_DSN=

# ── PythonAnywhere (deploy) ───────────────────────────────────
# Usado por: scripts/pull_db.py, scripts/deploy.py, GitHub Actions
PA_USER=NomeDoUtilizador
PA_TOKEN=token-api-pythonanywhere
PA_DOMAIN=nomedoutilizador.pythonanywhere.com

# ══════════════════════════════════════════════════════════════
#  Como usar localmente:
#    pip install python-dotenv
#    Adicionar ao app.py: from dotenv import load_dotenv; load_dotenv()
#
#  No PythonAnywhere (wsgi.py):
#    os.environ.setdefault("SECRET_KEY", "...")
#    os.environ.setdefault("VAPID_PRIVATE_KEY", "...")
#
#  No GitHub Actions:
#    Settings → Secrets → Actions → New repository secret
#    Criar: PA_USER, PA_TOKEN, PA_DOMAIN
# ══════════════════════════════════════════════════════════════
